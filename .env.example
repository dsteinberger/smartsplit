# SmartSplit — API keys
# Copy this file: cp .env.example .env
# Then fill in the keys you have (at least one free LLM key required)

# ── Free LLM providers (at least one required) ──────────────
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# ── Free backup LLMs (optional, lower quality) ──────────────
HF_TOKEN=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# ── Paid LLMs (optional, used as brain if set) ──────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# ── Search providers (optional, enables web search) ─────────
SERPER_API_KEY=
# TAVILY_API_KEY=

# ── SmartSplit settings (optional) ──────────────────────────
# SMARTSPLIT_BRAIN=groq          # force a specific brain provider
# SMARTSPLIT_MODE=balanced       # balanced | economy | quality
# SMARTSPLIT_PORT=8420
